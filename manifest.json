{
  "manifest_version": 3,
  "name": "Super Email Noticer",
  "short_name": "Super Email Noticer",
  "version": "1.1.0",
  "description": "Super Email Noticer — pastel-themed Chrome extension that notices email addresses on any webpage and visualises them in a friendly graph.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Super Email Noticer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
